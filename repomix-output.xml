  videos: 16
  frames: 2550
  cubes: 2486
  cells: 192
  feature rows: 477312

UCSD Ped2 test:
  videos: 12
  frames: 2010
  cubes: 1962
  cells: 192
  feature rows: 376704

UCSD Ped1 train:
  videos: 34
  frames: 6800
  cubes: 6664
  cells: 192
  feature rows: 1279488

UCSD Ped1 test:
  videos: 36
  frames: 7200
  cubes: 7056
  cells: 192
